	</column>
	<column name="launch_year">
		<type name="smallint" length="0"/>
	</column>
	<column name="engine_power">
		<type name="smallint" length="0"/>
	</column>
	<column name="length">
		<type name="decimal" length="0"/>
	</column>
	<column name="draught">
		<type name="decimal" length="0"/>
	</column>
	<column name="beam">
		<type name="decimal" length="0"/>
	</column>
	<column name="water_tank">
		<type name="integer" length="0"/>
	</column>
	<column name="fuel_tank">
		<type name="integer" length="0"/>
	</column>
	<column name="cabins">
		<type name="smallint" length="0"/>
	</column>
	<column name="crew_cabins">
		<type name="smallint" length="0"/>
	</column>
	<column name="wc">
		<type name="smallint" length="0"/>
	</column>
	<column name="crew_wc">
		<type name="smallint" length="0"/>
	</column>
	<column name="berths">
		<type name="smallint" length="0"/>
	</column>
	<column name="crew_berths">
		<type name="smallint" length="0"/>
	</column>
	<column name="max_persons">
		<type name="smallint" length="0"/>
		<comment> <![CDATA[Max number of people on board]]> </comment>
	</column>
	<column name="default_checkin">
		<type name="varchar" length="10"/>
		<comment> <![CDATA[Time of detault check-in]]> </comment>
	</column>
	<column name="default_checkout">
		<type name="varchar" length="10"/>
		<comment> <![CDATA[Time of default check-out]]> </comment>
	</column>
	<column name="mainsail_type">
		<type name="smallint" length="50"/>
		<comment> <![CDATA[Sail type]]> </comment>
	</column>
	<column name="mainsail_area">
		<type name="decimal" length="0"/>
	</column>
	<column name="genoa_type">
		<type name="smallint" length="50"/>
		<comment> <![CDATA[Sail type]]> </comment>
	</column>
	<column name="genoa_area">
		<type name="decimal" length="0"/>
	</column>
	<column name="registration_number">
		<type name="varchar" length="50"/>
		<comment> <![CDATA[MMK certificate, Nausys registrationNumber]]> </comment>
	</column>
	<column name="option_approval">
		<type name="boolean" length="0"/>
		<comment> <![CDATA[if created option needs to be approved by charter company]]> </comment>
	</column>
	<column name="option_to_reservation">
		<type name="boolean" length="0"/>
		<comment> <![CDATA[if you can create fix booking by yourself
(convert option to reservation) through
API or Agency portal, or you charter
company needs to do it for you]]> </comment>
	</column>
	<column name="commision">
		<type name="decimal" length="0"/>
		<comment> <![CDATA[Commision in total]]> </comment>
	</column>
	<column name="commision_perc">
		<type name="decimal" length="0"/>
		<comment> <![CDATA[MMK has only commision perc. We need to calc commision]]> </comment>
	</column>
	<column name="exclude_discount">
		<type name="boolean" length="0"/>
		<comment> <![CDATA[Exclude agency discount for this ship]]> </comment>
	</column>
	<column name="max_discount">
		<type name="decimal" length="0"/>
		<comment> <![CDATA[From Nausys. Not sure if needed]]> </comment>
	</column>
	<column name="agency_discount_type">
		<type name="varchar" length="50"/>
		<comment> <![CDATA[From Nausys. Not sure if needed]]> </comment>
	</column>
	<column name="max_discount_from_commision">
		<type name="decimal" length="0"/>
		<comment> <![CDATA[From Nausys. Not sure if needed]]> </comment>
	</column>
	<column name="charter_type">
		<type name="varchar" length="250"/>
		<comment> <![CDATA[Is bareboat or crewed - Nausys - charterType, MMK - products]]> </comment>
	</column>
	<column name="crewed_type">
		<type name="varchar" length="20"/>
		<comment> <![CDATA[Nausys - Indicates whether crewed charter type SKIPPER, SKIPPER_HOSTESS or
ALL_INCLUSIVE]]> </comment>
	</column>
	<column name="vessel_type" not-null="true">
		<type name="smallint" length="50"/>
		<comment> <![CDATA[Yacht type. MMK - Kind can be - Sail boat , Motor boat, Catamaran, Power Catamaran, Gulet, Motorsailer, Motoryacht, Trimaran, Other. Nausys - ???]]> </comment>
	</column>
	<column name="entry_type" not-null="true">
		<type name="smallint" length="0"/>
		<comment> <![CDATA[custom or external]]> </comment>
	</column>
	<column name="sys_active" not-null="true" default-value="true">
		<type name="boolean" length="0"/>
		<comment> <![CDATA[If yacht is deactivated (deleted) by external system.]]> </comment>
	</column>
	<column name="main_image_id">
		<type name="bigint" length="0"/>
	</column>
	<column name="deposit_currency">
		<type name="varchar" length="20"/>
	</column>
	<column name="crew_number">
		<type name="smallint" length="0"/>
	</column>
	<constraint name="yacht_pk" type="pk-constr" table="public.yacht">
		<columns names="id" ref-type="src-columns"/>
	</constraint>

	<customidxs object-type="column">
		<object name="agency_id" index="2"/>
		<object name="location_id" index="3"/>
		<object name="model_id" index="4"/>
	</customidxs>
	<customidxs object-type="constraint">
		<object name="agency_fk" index="1"/>
		<object name="location_fk" index="2"/>
		<object name="model_fk" index="3"/>
	</customidxs></table>

