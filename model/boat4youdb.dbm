<table name="reservation_options" layers="0" collapse-mode="2" max-obj-count="22" z-value="0">
	<schema name="public"/>
	<role name="boat4you_owner"/>
	<comment> <![CDATA[Reservation options like shorter than 7 day reservation, checkin days, etc]]> </comment>
	<position x="60" y="140"/>
	<column name="id" not-null="true">
		<type name="bigserial" length="0"/>
	</column>
	<column name="date_from" not-null="true">
		<type name="date" length="0"/>
	</column>
	<column name="date_to">
		<type name="date" length="0"/>
	</column>
	<column name="minimal_duration" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="checkin_mon" not-null="true">
		<type name="boolean" length="0"/>
	</column>
	<column name="checkin_tue" not-null="true">
		<type name="boolean" length="0"/>
