		<idxelement use-sorting="false">
			<column name="hash_code"/>
		</idxelement>
</index>

<constraint name="location_from_fk" type="fk-constr" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="NO ACTION" ref-table="public.location" table="public.offer">
	<columns names="location_from" ref-type="src-columns"/>
	<columns names="id" ref-type="dst-columns"/>
</constraint>

<constraint name="location_to_fk" type="fk-constr" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="NO ACTION" ref-table="public.location" table="public.offer">
	<columns names="location_to" ref-type="src-columns"/>
	<columns names="id" ref-type="dst-columns"/>
</constraint>

<constraint name="location_from_fk" type="fk-constr" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="NO ACTION" ref-table="public.location" table="public.reservation">
	<columns names="location_from" ref-type="src-columns"/>
	<columns names="id" ref-type="dst-columns"/>
</constraint>

<constraint name="location_to_fk" type="fk-constr" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="NO ACTION" ref-table="public.location" table="public.reservation">
	<columns names="location_to" ref-type="src-columns"/>
	<columns names="id" ref-type="dst-columns"/>
</constraint>

<relationship name="rel_offer_location" type="relfk" layers="0"
	 src-table="public.offer"
	 dst-table="public.location" reference-fk="location_from_fk"
