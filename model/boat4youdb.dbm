	<column name="director">
		<type name="varchar" length="100"/>
	</column>
	<column name="skip_external_system" not-null="true" default-value="false">
		<type name="boolean" length="0"/>
	</column>
	<constraint name="agency_pk" type="pk-constr" table="public.agency">
		<columns names="id" ref-type="src-columns"/>
	</constraint>
</table>

<table name="yacht" layers="0" collapse-mode="2" max-obj-count="54" z-value="0">
