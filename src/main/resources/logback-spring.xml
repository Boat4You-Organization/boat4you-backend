<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- LOG_DIR is the directory where log files (rolling/dev) land. Default
         is ./logs (relative to JVM working directory) for backward compat
         with the systemd unit WorkingDirectory=/home/cusmaN/boat4you. Ops can
         override via `Environment=LOG_DIR=/var/log/boat4you` in the systemd
         unit if logs ever need to land outside the working directory. -->
    <property name="LOG_DIR" value="${LOG_DIR:-./logs}"/>

    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%date{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} ${PID} [%thread] %-5level %logger{36}: %msg%n</pattern>
        </encoder>
    </appender>

    <root level="info">
        <appender-ref ref="Console"/>
    </root>

    <logger name="hr.workspace.boat4you" level="trace" additivity="false">
        <appender-ref ref="Console"/>
    </logger>

    <springProfile name="aws,prod">
        <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/boat4you-ws.log</file>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>%date{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} ${PID} [%thread] %-5level %logger{36}: %msg%n</pattern>
            </encoder>

            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/archived/boat4you-ws-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>60</maxHistory>
                <totalSizeCap>2GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <root level="info">
            <appender-ref ref="RollingFile"/>
            <appender-ref ref="Console"/>
        </root>

        <!-- INFO by default for prod. Env override (B4Y_LOG_LEVEL=debug) flips
             back to verbose when troubleshooting a specific incident; flip
             back once issue resolved. DEBUG-level prod logging amplifies
             PII visibility (e.g. InternalLoginException email logs at ERROR,
             UserMutationService debug-logs user.email) and fills the 2GB
             rolling cap faster under high traffic / attack load. -->
        <logger name="hr.workspace.boat4you" level="${B4Y_LOG_LEVEL:-info}" additivity="false">
            <appender-ref ref="RollingFile"/>
            <appender-ref ref="Console"/>
        </logger>
    </springProfile>

    <springProfile name="dev">
        <appender name="DevFile" class="ch.qos.logback.core.FileAppender">
            <file>${LOG_DIR}/boat4you-ws-dev.log</file>
            <append>true</append>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>%date{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} ${PID} [%thread] %-5level %logger{36}: %msg%n</pattern>
            </encoder>
        </appender>

        <root level="info">
            <appender-ref ref="DevFile"/>
            <appender-ref ref="Console"/>
        </root>

        <logger name="hr.workspace.boat4you" level="trace" additivity="false">
            <appender-ref ref="DevFile"/>
            <appender-ref ref="Console"/>
        </logger>
    </springProfile>

</configuration>