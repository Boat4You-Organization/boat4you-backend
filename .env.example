# Copy to .env and fill in real values. NEVER commit .env.

# --- Core secrets ---
JWT_SECRET_KEY=            # generate: openssl rand -hex 32
SSL_KEYSTORE_PASSWORD=     # password for boat4you_selfsigned.p12

# --- Database (runtime app user) ---
DB_HOST=localhost
DB_PORT=5434
DB_NAME=boat4you_db
DB_USER=boat4you_app
DB_PASSWORD=

# --- Flyway / DB owner (migration user) ---
FLYWAY_USER=boat4you_owner
FLYWAY_PASSWORD=
FLYWAY_OUT_OF_ORDER=false

# --- Mail (SMTP) ---
# Note: application.yml binds MAIL_HOST/PORT/USERNAME/PASSWORD (root profile).
# application-prod.yml overrides via MAIL_SERVER_HOST/... — keep both names
# in sync when wiring real values per environment.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_ENABLED=false

# --- NauSys ---
NAUSYS_URL=http://ws.nausys.com
NAUSYS_USERNAME=
NAUSYS_PASSWORD=

# --- MMK / Booking Manager ---
MMK_URL=https://www.booking-manager.com/api/v2
MMK_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Server ---
# SERVER_HOST_PUBLIC: the public-facing frontend origin used for Stripe
# success_url, email links, redirect-back paths. Next.js default = 3000.
SERVER_HOST=https://localhost:8443
SERVER_HOST_PUBLIC=http://localhost:3000
SERVER_HOST_ADMIN_PUBLIC=http://localhost:3000
SWAGGER_ENDPOINT_ENABLED=true