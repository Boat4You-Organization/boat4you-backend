# Copy to .env and fill in real values. NEVER commit .env.

# --- Core secrets ---
JWT_SECRET_KEY=            # generate: openssl rand -hex 32
SSL_KEYSTORE_PASSWORD=     # password for boat4you_selfsigned.p12

# --- Database (runtime app user) ---
DB_HOST=localhost
DB_PORT=5434
DB_NAME=boat4you_db
DB_USER=boat4you_app
DB_PASSWORD=

# --- Flyway / DB owner (migration user) ---
FLYWAY_USER=boat4you_owner
FLYWAY_PASSWORD=
FLYWAY_OUT_OF_ORDER=false

# --- Mail (SMTP) ---
MAIL_SERVER_HOST=smtp.gmail.com
MAIL_SERVER_PORT=587
MAIL_SERVER_USERNAME=
MAIL_SERVER_PASSWORD=
EMAIL_ENABLED=false

# --- NauSys ---
NAUSYS_URL=http://ws.nausys.com
NAUSYS_USERNAME=
NAUSYS_PASSWORD=

# --- MMK / Booking Manager ---
MMK_URL=https://www.booking-manager.com/api/v2
MMK_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Viva Payments ---
VIVA_OAUTH_URL=https://demo-accounts.vivapayments.com/connect/token
VIVA_API_URL=https://demo-api.vivapayments.com
VIVA_CHECKOUT_URL=https://demo.vivapayments.com/web/checkout
VIVA_SOURCE_CODE=
VIVA_MERCHANT_ID=
VIVA_WEBHOOK_VERIFICATION_API_KEY=
VIVA_WEBHOOK_VERIFICATION_BASE_URL=https://demo.vivapayments.com
VIVA_CLIENT_ID=
VIVA_CLIENT_SECRET=

# --- Server ---
SERVER_HOST=https://localhost:8443
SERVER_HOST_PUBLIC=http://localhost:5173
SERVER_HOST_ADMIN_PUBLIC=http://localhost:5173
SWAGGER_ENDPOINT_ENABLED=true